# Copy to .env and edit. Never commit .env (it's gitignored by the
# parent folder's .gitignore).

# --- Container user --------------------------------------------------------
# Find the right values with:
#   id -u    (PUID)
#   id -g    (PGID)
# These must match the owner of the media files in MEDIA_PATH below,
# otherwise Jellyfin can't read them.
PUID=1000
PGID=1000

# --- Locale ----------------------------------------------------------------
TZ=Europe/London

# --- Where your media lives ------------------------------------------------
# Absolute host path. Anything under here will appear inside the container
# at /media (read-only). Point this at a directory that already contains
# Movies/, Shows/, Music/ subfolders (or whatever structure you prefer —
# you'll map them to libraries in the Jellyfin admin UI).
MEDIA_PATH=/srv/media

# --- Public URL ------------------------------------------------------------
# How clients should reach this server. Use the LAN IP for now; switch
# to https://jellyfin.example.com once you put a reverse proxy in front.
JELLYFIN_URL=http://localhost:8096

# --- Hardware transcoding (only used if `devices:` is uncommented in
#     docker-compose.yml). Find with: getent group render | cut -d: -f3
# RENDER_GID=104
