# Copy to .env and edit.

# --- Version ---------------------------------------------------------------
# Pin both server + worker to the same version (they share migrations).
# Release notes: https://goauthentik.io/docs/releases/
AUTHENTIK_VERSION=2024.10.4

# --- Postgres --------------------------------------------------------------
# Internal to the authentik docker network — not exposed. Still pick a
# real password.
# Generate one with:  openssl rand -base64 36
PG_USER=authentik
PG_DB=authentik
PG_PASS=

# --- Authentik secret key --------------------------------------------------
# Used to sign cookies and tokens. REQUIRED. Leaking it means an
# attacker can forge sessions. Generate once and DO NOT rotate without
# accepting that all current sessions die.
# Generate with:  openssl rand -base64 60 | tr -d '\n'
AUTHENTIK_SECRET_KEY=

# --- Email (optional) ------------------------------------------------------
# Used for password reset emails, invitations, MFA recovery codes.
# Skip entirely (leave blank) if you don't need those flows yet.
# Works with any SMTP provider — Gmail app password, Mailgun, Postmark,
# Fastmail, etc.
AUTHENTIK_EMAIL__HOST=
AUTHENTIK_EMAIL__PORT=587
AUTHENTIK_EMAIL__USERNAME=
AUTHENTIK_EMAIL__PASSWORD=
AUTHENTIK_EMAIL__USE_TLS=true
AUTHENTIK_EMAIL__FROM=authentik@yourdomain.com
