# Copy to .env and edit.

# --- Server name (PERMANENT — chosen once) ---------------------------------
# This is the domain part of every user's Matrix ID. After first start
# it's baked into the database forever; changing it requires wiping
# everything. Pick the SHORT one — `yourdomain.com`, not
# `matrix.yourdomain.com` — so handles look like @you:yourdomain.com.
#
# The actual server can still live on a subdomain (matrix.yourdomain.com)
# — that's what the .well-known files in the README handle.
SERVER_NAME=yourdomain.com

# --- Registration ----------------------------------------------------------
# Knowing this lets anyone create an account. Generate with:
#   openssl rand -base64 24
# You'll need it once to create your own account, then share with
# friends you want to invite.
REGISTRATION_TOKEN=

# Allow ANY registration (token still required). Set false once you've
# created the accounts you want — stops drive-by attempts.
ALLOW_REGISTRATION=true

# --- Federation ------------------------------------------------------------
# true  = chat with matrix.org and any other federated homeserver
# false = walled garden, your homeserver only
ALLOW_FEDERATION=true
