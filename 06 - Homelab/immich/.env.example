# Copy to .env and edit. Never commit .env.

# --- Version (all four images must match) ----------------------------------
# Bump procedure:
#   1. Check release notes at https://github.com/immich-app/immich/releases
#      especially for "breaking" or "migration" mentions.
#   2. Update the tag here, then `docker compose pull && docker compose up -d`.
#   3. Server will run DB migrations automatically on startup.
IMMICH_VERSION=v1.121.0

# --- Where photo/video originals live -------------------------------------
# Bind mount onto a path with plenty of free disk. For a NAS deployment
# this would typically be an NFS or SMB mount on the host, or a local
# path on the NAS itself if you're running Immich on the NAS.
#
# Layout Immich creates inside this folder (don't touch by hand):
#   upload/            files being processed
#   library/           processed originals, organised by user
#   thumbs/            generated thumbnails
#   encoded-video/     transcoded video for streaming
#   profile/           user avatars
UPLOAD_LOCATION=/srv/immich/library

# --- Database --------------------------------------------------------------
# Internal to the immich docker network — not reachable from outside.
# Still set a real password; defense in depth.
DB_USERNAME=postgres
DB_PASSWORD=changemepleasechangeme
DB_DATABASE_NAME=immich

# --- Timezone --------------------------------------------------------------
TZ=Europe/London

# --- Hardware acceleration (only used if uncommented in compose) ----------
# RENDER_GID=104     # getent group render | cut -d: -f3
