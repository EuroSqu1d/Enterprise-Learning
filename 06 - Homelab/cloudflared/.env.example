# Copy to .env and edit. Never commit .env — it contains a credential
# that gives anyone holding it the ability to route traffic into your
# homelab via your Cloudflare tunnel.

# Get this from the Cloudflare Zero Trust dashboard:
#   Networks -> Tunnels -> [your tunnel] -> Configure
#   Under "Install and run a connector", copy the long string after
#   `--token` from the docker example. That whole opaque blob is the
#   token. It is account-scoped + tunnel-scoped, not your CF API key.
TUNNEL_TOKEN=paste-the-long-string-here
