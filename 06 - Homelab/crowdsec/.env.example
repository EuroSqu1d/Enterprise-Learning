# Copy to .env and edit.

# --- Container user --------------------------------------------------------
# CrowdSec runs as this GID. 1000 is the first non-root user on
# Ubuntu/Debian — same as the other services. Find with: id -g
GID=1000

# --- CrowdSec central console (optional, free) ----------------------------
# Sign up at https://app.crowdsec.net for a web dashboard showing all
# your alerts + community blocklist visibility. After signup, copy the
# enrollment key shown when you "Add an instance". Leave empty to skip.
CROWDSEC_ENROLL_KEY=

# --- Cloudflare bouncer ---------------------------------------------------
# Filled in AFTER first start. README has the exact commands.
#
# BOUNCER_KEY_CF: generated by running on the homelab host:
#   docker compose exec crowdsec cscli bouncers add cf-bouncer
#
# CF_API_TOKEN: created at https://dash.cloudflare.com/profile/api-tokens
# with permissions:
#   Account - Account Filter Lists: Edit
#   Zone    - Zone WAF: Edit
#   Zone    - Zone: Read
# Scoped to the specific zone(s) you want protected.
#
# CF_ZONE_IDS: find on each domain's overview page in CF dashboard
# (right sidebar). Comma-separated if you have multiple zones.
BOUNCER_KEY_CF=fill-in-after-step-4
CF_API_TOKEN=fill-in-after-step-5
CF_ZONE_IDS=fill-in-after-step-5
