# --- Grafana ---------------------------------------------------------------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme
# Update this once you put Grafana behind the cloudflared tunnel.
GF_SERVER_ROOT_URL=http://localhost:3000

# --- Alertmanager ----------------------------------------------------------
# Where to POST alerts. Leave empty to disable notifications (Alertmanager
# will still group/dedupe alerts, just not send anywhere).
#
# Examples:
#   Discord:  https://discord.com/api/webhooks/<id>/<token>/slack
#             (the /slack suffix is important - reuses Slack payload format)
#   Slack:    https://hooks.slack.com/services/T.../B.../...
#   ntfy:     https://ntfy.sh/your-private-topic-name
ALERT_WEBHOOK_URL=
