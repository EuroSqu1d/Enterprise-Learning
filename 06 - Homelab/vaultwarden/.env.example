# Copy to .env and edit.

# --- Required --------------------------------------------------------------
# The public URL clients will hit. Must match the CF Tunnel hostname
# exactly. Must be HTTPS — the Bitwarden apps refuse to connect to a
# plain-HTTP server.
DOMAIN=https://vault.yourdomain.com

# --- Account control -------------------------------------------------------
# Step-by-step setup:
#   1. Leave SIGNUPS_ALLOWED=true here for the very first start.
#   2. Bring up the stack, browse to $DOMAIN, click "Create account",
#      register your own user. This is the only account you actually
#      want on the server.
#   3. Set SIGNUPS_ALLOWED=false below and `docker compose up -d` to
#      apply. From now on no one else can register.
SIGNUPS_ALLOWED=true

# Lets existing users invite others by email (needs SMTP configured
# below). Independent of SIGNUPS_ALLOWED — invited users can still
# join even when signups are closed.
INVITATIONS_ALLOWED=true

# --- Admin panel (optional, leave empty by default) ------------------------
# Empty string = /admin is disabled = safer default.
# Set this only when you actively need the admin panel, then unset.
# Generate a random token with:
#   openssl rand -base64 48
# Or, recommended, use an argon2 hash — see the README.
ADMIN_TOKEN=

# --- Optional toggles ------------------------------------------------------
SENDS_ALLOWED=true
EMERGENCY_ACCESS_ALLOWED=true
WEB_VAULT_ENABLED=true

# --- Networking ------------------------------------------------------------
# Cloudflare-aware IP header so per-IP login throttling sees the real
# client, not CF's edge. Leave unchanged unless you change the proxy.
IP_HEADER=CF-Connecting-IP

# warn | info | debug | trace — turn up only while troubleshooting.
LOG_LEVEL=warn

# --- SMTP (optional) -------------------------------------------------------
# Fill in only if you want invitation emails / password hints / 2FA-by-email.
# Gmail app passwords work. So does any transactional email provider.
# SMTP_HOST=smtp.example.com
# SMTP_FROM=vault@yourdomain.com
# SMTP_PORT=587
# SMTP_SECURITY=starttls
# SMTP_USERNAME=
# SMTP_PASSWORD=
