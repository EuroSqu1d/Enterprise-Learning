# Copy to .env and edit.

# --- Container user --------------------------------------------------------
PUID=1000
PGID=1000
TZ=Europe/London

# --- Laravel APP_KEY -------------------------------------------------------
# REQUIRED. Generate once with:
#   docker run --rm ghcr.io/alexjustesen/speedtest-tracker:v0.21.2 \
#     php artisan key:generate --show
# Paste the full output (starts with "base64:") here:
APP_KEY=

# --- Test schedule (cron syntax) -------------------------------------------
# Default = every hour on the hour. Other useful values:
#   "*/15 * * * *"   every 15 minutes
#   "0 */6 * * *"    every 6 hours
#   "0 8,12,18 * * *"  morning/noon/evening
SPEEDTEST_SCHEDULE=0 * * * *

# --- Pin to specific Ookla servers (optional) ------------------------------
# Comma-separated server IDs. Leave empty to auto-pick each run.
# Find IDs at https://www.speedtest.net/speedtest-servers.php
SPEEDTEST_SERVERS=
